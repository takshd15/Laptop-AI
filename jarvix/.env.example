OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434/api/chat

GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_TOKEN_FILE=secrets/google_token.json

TIMEZONE=Europe/Amsterdam

USER_DISPLAY_NAME=Mr Taksh
JARVIX_GREETING=Welcome back

# Speech-to-text: tiny.en (fastest) or base.en (more accurate). CPU-friendly.
STT_MODEL=tiny.en
VOICE_RECORD_SECONDS=5
WAKE_MODE=clap

AUTO_OPEN_APP_ON_WAKE=cursor
AUTO_OPEN_FOLDER_ON_WAKE=jarvix
AUTO_START_MUSIC_ON_WAKE=true

# Optional future Spotify API (basic media keys are used until these are set).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
