OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434/api/chat

GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_TOKEN_FILE=secrets/google_token.json

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_TOKEN_FILE=secrets/spotify_token.json

TIMEZONE=Europe/Amsterdam
DEFAULT_WEATHER_LOCATION=Enschede
WEATHER_TIMEOUT_SECONDS=5

USER_DISPLAY_NAME=Mr Taksh Dange
JARVIX_GREETING=Welcome back

# Speech-to-text: tiny.en (fastest) or base.en (more accurate). CPU-friendly.
STT_MODEL=base.en
VOICE_RECORD_SECONDS=4
MIC_SILENCE_THRESHOLD=0.0015
WAKE_DEBUG=false
# Wake trigger: wakeword ("hey jarvis") | clap | enter
WAKE_MODE=wakeword
WAKE_WORD=jarvis

AUTO_OPEN_APP_ON_WAKE=vscode
AUTO_OPEN_FOLDER_ON_WAKE=
AUTO_START_MUSIC_ON_WAKE=true
AUTO_MUSIC_QUERY_ON_WAKE=Should I Stay or Should I Go
AUTO_MUSIC_URI_ON_WAKE=https://open.spotify.com/track/39shmbIHICJ2Wxnk1fPSdz

TTS_RATE=185
TTS_VOLUME=1.0
TTS_VOICE_HINTS=george,david,male,english
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_16000
ELEVENLABS_TIMEOUT_SECONDS=8
ELEVENLABS_STABILITY=0.62
ELEVENLABS_SIMILARITY_BOOST=0.86
ELEVENLABS_STYLE=0.08
ELEVENLABS_SPEAKER_BOOST=true

# Optional future Spotify API (basic media keys are used until these are set).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
